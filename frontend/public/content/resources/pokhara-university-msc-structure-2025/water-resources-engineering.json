            { "name": "Hydraulic Jump Sequent Depth", "expr": "y₂/y₁ = ½[√(1 + 8Fr₁²) - 1]" },
            { "name": "Rectangular Weir Discharge", "expr": "Q = (2/3) C_d √(2g) b H^(3/2)" },
