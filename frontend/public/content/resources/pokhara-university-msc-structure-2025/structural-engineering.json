              [
                "STRESS",
                "Force per unit area on a member; σ = F / A; Types: axial, bending, shear, torsion.",
                ""
              ],
              ["STRAIN", "Deformation per unit length; ε = ΔL / L; Types: normal, shear.", ""],
              [
                "HOOKE'S LAW",
                "Stress is proportional to strain for elastic material: σ = E ε; E = modulus of elasticity.",
                ""
              ],
              [
                "POISSON'S RATIO",
                "Ratio of lateral strain to longitudinal strain: ν = ε_lat / ε_long.",
                ""
              ],
              [
                "STRESS-STRAIN RELATIONSHIPS",
                "Axial: σ = F/A; Shear: τ = V/A; Bending: σ = M y / I; Torsion: τ = T ρ / J.",
                ""
              ],
              [
                "TEMPERATURE STRESSES",
                "ΔL = α L ΔT; σ = E α ΔT; α = coefficient of thermal expansion.",
                ""
