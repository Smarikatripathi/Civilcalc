      "sections": [
        {
          "type": "table",
          "level": 3,
          "title": "Beams – Bending & Shear",
          "table": {
            "header": ["SUB-TOPIC", "SHORT DESCRIPTION / NOTES", "EXTRA"],
            "rows": [
              [
                "SIMPLE BEAM",
                "Supported at ends, carries vertical loads; Reactions determined by equilibrium.",
                ""
              ],
              [
                "SHEAR FORCE (SF)",
                "Internal force along section resisting sliding; Positive when left segment tends up.",
                ""
              ],
              [
                "BENDING MOMENT (BM)",
                "Internal moment resisting bending; Positive when concave up (sagging).",
                ""
              ],
              [
                "SF & BM DIAGRAMS",
                "Plot variation along beam; Use relations: dV/dx = -w(x), dM/dx = V(x).",
                ""
              ],
              [
                "UNIFORMLY DISTRIBUTED LOAD (UDL)",
                "SF slope = -w, BM slope = V; Max BM at midspan for simply supported.",
                ""
              ],
              [
                "POINT LOAD",
                "SF changes abruptly; BM linear between points; Max at load location.",
                ""
              ],
              ["CONCENTRATED MOMENT", "SF continuous; BM jumps by applied moment.", ""]
            ]
          }
        },
        {
          "type": "formulas",
          "level": 3,
          "title": "Beam Analysis Formulas",
          "items": [
            { "name": "Bending stress", "expr": "σ = M y / I" },
            { "name": "Shear stress", "expr": "τ = V Q / (I b)" },
            { "name": "Relation SF & Load", "expr": "dV/dx = -w(x)" },
            { "name": "Relation BM & SF", "expr": "dM/dx = V(x)" },
            { "name": "Max bending moment (simply supported, UDL)", "expr": "Mmax = w L² / 8" },
            { "name": "Max bending moment (point load center)", "expr": "Mmax = P L / 4" }
          ]
        },
