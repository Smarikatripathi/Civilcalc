        {
          "type": "formulas",
          "level": 3,
          "title": "Important Formulas",
          "items": [
            {
              "name": "Derivative of sum/product/quotient",
              "expr": "(f+g)'=f'+g', (fg)'=f'g + fg', (f/g)'=(f'g - fg')/g²"
            },
            { "name": "Integration by parts", "expr": "∫u dv = uv - ∫v du" },
            { "name": "Curvature", "expr": "k = |d²y/dx²| / (1+(dy/dx)²)^(3/2)" },
            { "name": "Dot product", "expr": "A·B = |A||B|cosθ" },
            { "name": "Cross product", "expr": "A×B = |A||B|sinθ n̂" },
            {
              "name": "ODE (1st order linear)",
              "expr": "dy/dx + P(x)y = Q(x) → solution y = e^(-∫Pdx) ∫Q e^(∫Pdx) dx"
            }
          ]
        },
