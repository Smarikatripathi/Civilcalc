        {
          "type": "formulas",
          "level": 3,
          "title": "Key Formulas (as per notes)",
          "items": [
            {
              "name": "Stopping Sight Distance (SSD)",
              "expr": "SSD = 0.278 V t + V² / [254 (f ± G)]"
            },
            {
              "name": "Overtaking Sight Distance (OSD)",
              "expr": "OSD = d1 + d2 + d3 (≈ 640 m for 100 km/h)"
            },
            { "name": "Intermediate Sight Distance (ISD)", "expr": "ISD = 2 × SSD" },
            { "name": "Length of simple circular curve", "expr": "L = (π R Δ) / 180" },
            { "name": "Tangent length", "expr": "T = R tan(Δ / 2)" },
            { "name": "Superelevation (IRC form)", "expr": "e = V² / (127 R) − f" },
            { "name": "Transition curve length", "expr": "Ls = 0.0215 V³ / (C R)" },
            { "name": "Extra widening", "expr": "We = (n l²) / (2 R) + V / (9.5 √R)" }
          ]
        },
