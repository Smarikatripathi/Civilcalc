            { "name": "Superelevation (for curves)", "expr": "e = V²/(127 R) − f" },
            { "name": "PCC slab stress (flexural)", "expr": "σ = 6 M / (b h²)" },
            {
              "name": "Load transfer efficiency (LTE)",
              "expr": "LTE = (Δunloaded / Δloaded) × 100%"
            },
            {
              "name": "Compaction degree",
              "expr": "Degree of compaction = (Field dry density / MDD) × 100%"
